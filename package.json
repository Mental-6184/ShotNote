{
  "name": "shotnote",
  "version": "1.0.0",
  "description": "Windows screenshot annotation app",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "icons": "powershell -ExecutionPolicy Bypass -File tools/generate-icons.ps1",
    "pack": "electron-builder --dir",
    "build": "electron-builder"
  },
  "dependencies": {
    "screenshot-desktop": "^1.15.4",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.shotnote.app",
    "productName": "ShotNote",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
